{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "setupFiles": ["<rootDir>/test/setup-e2e-env.ts"],
  "testTimeout": 30000,
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "testPathIgnorePatterns": ["/node_modules/"]
}
