DATABASE_URL=
DIRECT_URL=
REDIS_URL=
JWT_SECRET=
OTP_HMAC_SECRET=
# Production: required, min 16 characters. Used by POST /api/v1/admin/login (MVP admin JWT).
ADMIN_PASSWORD=
RESEND_API_KEY=
EMAIL_FROM=
# Optional: Nodemailer fallback when Resend returns an error (set with RESEND_API_KEY).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# true for SMTPS (e.g. port 465); omit or false for STARTTLS on 587
SMTP_SECURE=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_FLOW_TEMPLATE_ID=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Optional: max presigned upload-URL generations per user per UTC clock hour (default 30).
UPLOAD_URL_GEN_PER_HOUR=
# E2E/tests only: set true to skip upload URL rate limits.
UPLOAD_RATE_LIMIT_OFF=
GOOGLE_MAPS_API_KEY=
# Server key for Places Details + Distance Matrix (validate-place, commute). Enable those APIs in Google Cloud;
# billing is often required for traffic-aware Matrix. Use a server-usable key (IP restriction or unrestricted). A
# browser-only key with HTTP-referrer restrictions returns REQUEST_DENIED from this backend.
# Optional: max Distance Matrix requests per UTC day (default 1000).
MAPS_DAILY_BUDGET=
# E2E only: set true with a real GOOGLE_MAPS_API_KEY to run live Distance Matrix commute tests (`npm run test:e2e`).
RUN_EXTERNAL_API_TESTS=
SENTRY_DSN_API=
NODE_ENV=
PORT=
CORS_ORIGIN=http://localhost:3000
# Vercel UI + separate API host: set true if sessions still drop (some hosts do not set NODE_ENV=production).
SESSION_CROSS_SITE_COOKIES=
# Rare: set false to drop Partitioned on session cookies (only applies when cross-site cookies are on).
SESSION_COOKIE_PARTITIONED=
# Set SEED_USERS=true to create dev accounts when running `npm run seed` (requires NODE_ENV=development, or set SEED_ALLOW_NON_DEV=true for a pointed-at staging DB).
SEED_USERS=
SEED_ALLOW_NON_DEV=
# When true, `npm run seed` upserts Alt Mobility demo users (pushpander@ / prince@); or use NODE_ENV=development.
SEED_DEMO_ACCOUNTS=true
# Production: set true to enable static OTP (347612) + skip outbound mail for allowlisted demo emails only.
DEMO_AUTH_BYPASS=true
# Set true to run `npm run update-listing-photos` when NODE_ENV is not development (staging only).
UPDATE_LISTING_PHOTOS=
# Optional: max GET /browse/flats + /browse/flatmates per user per UTC day (default 1000). Lower in e2e to test 429.
BROWSE_DAILY_MAX=5000
# Messaging: Redis sliding windows. Set MESSAGING_RATE_LIMIT_OFF=true in tests to skip limits. Optional numeric overrides for e2e.
MESSAGING_RATE_LIMIT_OFF=false
MESSAGING_NEW_CONV_MAX=10
MESSAGING_MSG_PER_MIN=60
